# Public browser API base (same-origin rewrite — keep default)
NEXT_PUBLIC_API_BROWSER_BASE=/api/v1

# Backend origin for Next.js rewrites (no path, no trailing slash)
# Local: http://127.0.0.1:4000
# Remote: https://cleanshelfapi.emmerce.io
BACKEND_ORIGIN=http://127.0.0.1:4000

# Server-side fetches from RSC (direct to backend — include /api/v1 if your app uses it)
API_INTERNAL_BASE=http://127.0.0.1:4000/api/v1

# Absolute base for media URLs when API returns relative paths (/uploads/...)
NEXT_PUBLIC_MEDIA_ORIGIN=http://127.0.0.1:4000

# Session cookie from Admin backend (default shopflow.sid)
NEXT_PUBLIC_SESSION_COOKIE_NAME=shopflow.sid

# --- Example: local frontend → remote API (copy to .env.local) ---
# NEXT_PUBLIC_API_BROWSER_BASE=/api/v1
# BACKEND_ORIGIN=https://cleanshelfapi.emmerce.io
# API_INTERNAL_BASE=https://cleanshelfapi.emmerce.io/api/v1
# NEXT_PUBLIC_MEDIA_ORIGIN=https://cleanshelfapi.emmerce.io
# NEXT_PUBLIC_SESSION_COOKIE_NAME=shopflow.sid
#
# Backend must allow CORS from http://localhost:3000 with credentials.
# Restart `next dev` after changing BACKEND_ORIGIN (used in next.config rewrites).
